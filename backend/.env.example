# Backend environment variables — copy to backend/.env for local development
# NEVER commit the actual .env file to version control

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://giftstudio:giftstudio@localhost:5433/giftstudio

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (comma-separated, no trailing spaces) ────────────────────────────────
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
